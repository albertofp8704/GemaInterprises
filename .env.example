# ── Required ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-super-secret-jwt-key-here

# Generate with: python -c "import secrets; print(secrets.token_hex(24))"
INTERNAL_API_KEY=your-internal-api-key-here

# Railway auto-sets this when you add a PostgreSQL plugin
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Stripe (get from dashboard.stripe.com) ───────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Web3 / Wallet (set after deploying contracts) ────────────────────────────
GOAT_TOKEN_ADDRESS=0x...
LEGACY_NFT_ADDRESS=0x...
FLASHCARD_NFT_ADDRESS=0x...
BACKEND_WALLET_KEY=0x...        # Private key of the contract owner wallet
WEB3_RPC_URL=https://polygon-rpc.com

# ── Mobile app ───────────────────────────────────────────────────────────────
GOAT_API_URL=https://gemainterprises-production-a30b.up.railway.app
