{
  "name": "gema-desktop-agent",
  "version": "1.0.0",
  "description": "GEMA — Holographic Desktop AI Agent",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.gemainterprises.agent",
    "productName": "GEMA Agent",
    "directories": { "output": "dist" },
    "files": [
      "main.js",
      "preload.js",
      "agent.html",
      "setup.html",
      "assets/**"
    ],
    "win": {
      "target": [{ "target": "portable", "arch": ["x64"] }]
    },
    "portable": {
      "splashImage": false
    }
  },
  "author": "Gema Interprises",
  "dependencies": {},
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  }
}
